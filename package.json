{
  "name": "@smartsbio/jupyterlab-extension",
  "version": "0.1.8",
  "description": "smarts.bio AI-powered bioinformatics directly in JupyterLab",
  "keywords": [
    "jupyter",
    "jupyterlab",
    "jupyterlab-extension",
    "bioinformatics",
    "ai"
  ],
  "homepage": "https://smarts.bio",
  "bugs": {
    "url": "https://github.com/smartsbio/smarts-bio-jupyterlab/issues"
  },
  "license": "MIT",
  "author": "smarts.bio",
  "files": [
    "lib/**/*.{d.ts,eot,gif,html,js,js.map,json,png,svg,woff2,ttf}",
    "style/**/*.{css,js,eot,gif,html,jpg,png,svg,woff2,ttf}",
    "schema/**/*.json"
  ],
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "style": "style/index.css",
  "repository": {
    "type": "git",
    "url": "https://github.com/smartsbio/smarts-bio-jupyterlab.git"
  },
  "scripts": {
    "build": "jlpm run build:lib && jlpm run build:labextension:dev",
    "build:prod": "jlpm run clean && jlpm run build:lib:prod && jlpm run build:labextension",
    "build:labextension": "jupyter labextension build .",
    "build:labextension:dev": "jupyter labextension build --development True .",
    "build:lib": "tsc --sourceMap",
    "build:lib:prod": "tsc",
    "clean": "jlpm run clean:lib",
    "clean:lib": "rimraf lib tsconfig.tsbuildinfo",
    "clean:lintcache": "rimraf .eslintcache .stylelintcache",
    "clean:labextension": "rimraf smarts_bio_jupyterlab/labextension",
    "clean:all": "jlpm run clean:lib && jlpm run clean:labextension && jlpm run clean:lintcache",
    "eslint": "jlpm eslint:check --fix",
    "eslint:check": "eslint . --cache --ext .ts,.tsx",
    "install:extension": "jlpm run build",
    "lint": "jlpm stylelint && jlpm prettier && jlpm eslint",
    "lint:check": "jlpm stylelint:check && jlpm prettier:check && jlpm eslint:check",
    "prettier": "jlpm prettier:base --write --list-different",
    "prettier:base": "prettier \"**/*{.ts,.tsx,.js,.jsx,.css,.json,.md}\"",
    "prettier:check": "jlpm prettier:base --check",
    "stylelint": "jlpm stylelint:check --fix",
    "stylelint:check": "stylelint --cache \"style/**/*.css\"",
    "watch": "run-p watch:src watch:labextension",
    "watch:src": "tsc -w --sourceMap",
    "watch:labextension": "jupyter labextension watch ."
  },
  "dependencies": {
    "@jupyterlab/application": "^4.0.0",
    "@jupyterlab/apputils": "^4.0.0",
    "@jupyterlab/cells": "^4.0.0",
    "@jupyterlab/codeeditor": "^4.0.0",
    "@jupyterlab/docmanager": "^4.0.0",
    "@jupyterlab/docregistry": "^4.0.0",
    "@jupyterlab/notebook": "^4.0.0",
    "@jupyterlab/settingregistry": "^4.0.0",
    "@jupyterlab/statedb": "^4.0.0",
    "@jupyterlab/statusbar": "^4.0.0",
    "@jupyterlab/ui-components": "^4.0.0",
    "@lumino/widgets": "^2.0.0",
    "@smartsbio/ui": "^0.1.14",
    "marked": "^17.0.4",
    "react": "^18.2.0",
    "react-bootstrap-icons": "^1.11.6",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@jupyterlab/builder": "^4.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "npm-run-all": "^4.1.5",
    "rimraf": "~5.0.1",
    "typescript": "~5.0.0"
  },
  "peerDependencies": {
    "@jupyterlab/application": "^4.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "sideEffects": [
    "style/*.css",
    "style/index.js"
  ],
  "styleModule": "style/index.js",
  "jupyterlab": {
    "extension": true,
    "outputDir": "smarts_bio_jupyterlab/labextension",
    "schemaDir": "schema"
  },
  "jupyter-releaser": {
    "hooks": {
      "before-build-npm": [
        "python -m pip install jupyterlab~=4.0",
        "jlpm"
      ],
      "before-build-python": [
        "jlpm run build:prod"
      ]
    }
  }
}
